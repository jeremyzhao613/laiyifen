    {
      "id": "1775752097077",
      "data": {
        "desc": "根据用户身份、问题文本、页面上下文和附件状态，将请求路由到对应能力分支。",
        "type": "question-classifier",
        "model": {
          "mode": "chat",
          "name": "deepseek-v4-flash",
          "provider": "langgenius/deepseek/deepseek",
          "completion_params": {
            "temperature": 0
          }
        },
        "title": "总入口问题分类器",
        "vision": {
          "enabled": false
        },
        "classes": [
          {
            "id": "1",
            "name": "政策规则知识问答：公司政策、合作规则、活动规则、权限说明、FAQ、操作手册。"
          },
          {
            "id": "2",
            "name": "菜单定位与操作引导：功能入口、下一步操作、页面跳转、待办入口、合同入口、报名入口。"
          },
          {
            "id": "3",
            "name": "数据查询与分析：经营数据、订单、库存、叫货、对账、分润、费用、销售、指标异常。"
          },
          {
            "id": "4",
            "name": "任务执行与表单办理：表单填写、流程办理、进度追踪、导出、预约、报名、提交。"
          },
          {
            "id": "5",
            "name": "附件多模态识别：图片、截图、PDF、Excel、Word、视频、线下表单、合同、票据识别。"
          },
          {
            "id": "6",
            "name": "工单与人工客服：转人工、工单状态、评价服务、客服回复、飞书通知、服务时间。"
          },
          {
            "id": "7",
            "name": "主动服务与节点提醒：今日待办、商机提醒、入驻后通知、合同订单结算节点、指标预警。"
          },
          {
            "id": "8",
            "name": "系统异常与缺陷：页面加载失败、系统卡死、按钮不可用、AI回答异常、接口错误、功能缺陷。"
          },
          {
            "id": "9",
            "name": "其他问题：无法归入以上分类、信息不足、闲聊或超出业务范围，需要兜底追问。"
          }
        ],
        "selected": false,
        "description": "读取用户请求，按问题类型与关键词进行分流。",
        "instruction": "只选择一个最匹配分类，不要输出解释。\n优先根据 customer_issue 判断，issue_type 仅作辅助参考。\n涉及入口、在哪里、下一步、怎么操作、跳转、待办、合同授权入口，选择“菜单定位与操作引导”。\n涉及真实数据、状态、订单、库存、对账、分润、费用、指标，选择“数据查询与分析”。\n涉及提交、办理、导出、预约、报名、填表、审批，选择“任务执行与表单办理”。\n涉及图片、截图、文件、PDF、Excel、OCR、页面理解、信息提取，选择“附件多模态识别”。\n涉及转人工、工单、评价、客服回复、飞书，选择“工单与人工客服”。\n涉及每日待办、节点提醒、商机提醒、主动推送、指标预警，选择“主动服务与节点提醒”。\n涉及加载失败、卡死、按钮不可用、接口错误或 AI 回答异常，选择“系统异常与缺陷”。\n无法判断或信息不足时选择“其他问题”。",
        "instructions": "只选择一个最匹配分类，不要输出解释。\n优先根据 customer_issue 判断，issue_type 仅作辅助参考。\n涉及入口、在哪里、下一步、怎么操作、跳转、待办、合同授权入口，选择“菜单定位与操作引导”。\n涉及真实数据、状态、订单、库存、对账、分润、费用、指标，选择“数据查询与分析”。\n涉及提交、办理、导出、预约、报名、填表、审批，选择“任务执行与表单办理”。\n涉及图片、截图、文件、PDF、Excel、OCR、页面理解、信息提取，选择“附件多模态识别”。\n涉及转人工、工单、评价、客服回复、飞书，选择“工单与人工客服”。\n涉及每日待办、节点提醒、商机提醒、主动推送、指标预警，选择“主动服务与节点提醒”。\n涉及加载失败、卡死、按钮不可用、接口错误或 AI 回答异常，选择“系统异常与缺陷”。\n无法判断或信息不足时选择“其他问题”。",
        "query_variable_selector": [
          "1775752030903",
          "customer_issue"
        ]
      },
